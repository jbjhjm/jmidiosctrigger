<?xml version="1.0" encoding="utf-8"?>

<jmididata>
  
  <config>
	<IP value="127.0.0.1" />
	<Port value="4560" />
	<PortFallback value="4567" />
	<Filter_maxNote value="16" />
	<Filter_extraChannel value="10" />
