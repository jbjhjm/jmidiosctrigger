    <mapping channel="1" key="002" command="/executor/202/go" />
    <mapping channel="1" key="003" command="/executor/202/off" />
	
    <mapping channel="1" key="004" command="/executor/1.3"><param type="f" value="50" /></mapping>
    <mapping channel="1" key="005" command="/executor/1.3" ><param type="f" value="$velocity" multiplier="0.2" /></mapping>
    <mapping channel="1" key="006" command="/executor/1.3" ><param type="f" value="$fadeSpeed" multiplier="0.2" /></mapping>
    <mapping channel="1" key="007" command="/executor/1.3" ><param type="f" value="$velocity" /><param type="f" value="$fadeSpeed2" multiplier="0.1" /></mapping>

    <mapping channel="1" key="008" command="~SetValue/fadeSpeed"></mapping>
    <mapping channel="1" key="009" command="~SetValue/fadeSpeed2"></mapping>
    <mapping channel="1" key="010" command="~Reset"></mapping>

    <mapping channel="2" key="006" command="/executor/202/goto/4.2" />
