<?xml version="1.0" encoding="utf-8"?>

<jmididata>
  
  <config>
	<IP value="127.0.0.1" />
	<Port value="4560" />
	<PortFallback value="4567" />
	<Filter_maxNote value="12" />
	<Filter_extraChannel value="1" />
  </config>
  
  <variables>
	<var name="fadeSpeed" type="f" default="1.0" />
	<var name="fadeSpeed2" type="f" default="0.1" />
	<var name="xx3" type="f" default="1.1" />
	<var name="what" type="s" default="Fader" />
  </variables>

  <!-- all variables will have a range of 0-100.0 - use param[multiplier] to map their range if needed.  -->

  <mappings>
  	<!-- Channel 1 = Song executors  -->
    <mapping channel="1" key="000" command="~Reset"></mapping>
    <mapping channel="1" key="001" command="~SetValue/fadeSpeed"></mapping>
    <mapping channel="1" key="002" command="~SetValue/fadeSpeed2"></mapping>
    <mapping channel="1" key="003" command="/fader/3"><param type="f" value="$velocity" /></mapping>
    <mapping channel="1" key="004" command="/fader/4"><param type="f" value="$velocity" /></mapping>
    <mapping channel="1" key="005" command="/fader/5"><param type="f" value="$velocity" /></mapping>
    <mapping channel="1" key="006" command="/fader/6"><param type="f" value="$velocity" /></mapping>
    <mapping channel="1" key="007" command="/fader/7"><param type="f" value="$velocity" /></mapping>
    <mapping channel="1" key="008" command="/fader/8"><param type="f" value="$velocity" /></mapping>
    <mapping channel="1" key="009" command="/fader/9"><param type="f" value="$velocity" /></mapping>
    <mapping channel="1" key="010" command="/fader/10"><param type="f" value="$velocity" /></mapping>

    <mapping channel="1" key="012" command="/cmd"><param type="s" value="$what $xx3 At 100 Fade $fadeSpeed2 " /></mapping>
    <mapping channel="1" key="013" command="/executor/202/goto/4.2" />
    <mapping channel="1" key="014" command="/page/Master~Ch8" />
    <mapping channel="1" key="015" command="/page/Master~Ch8/executor/Sunstrips"><param type="f" value="25.0" /></mapping>
    <mapping channel="1" key="016" command="/executor/202/goto/4.2"><param type="f" value="0.5" /></mapping>

    <mapping channel="1" key="020" command="/macro/100"  />
    <mapping channel="1" key="021" command="/page/16" />
    <mapping channel="1" key="022" command="/executor/202/go" />
    <mapping channel="1" key="023" command="/executor/202/off" />
	
    <mapping channel="1" key="024" command="/executor/1.3"><param type="f" value="50" /></mapping>
    <mapping channel="1" key="025" command="/executor/1.3" ><param type="f" value="$velocity" multiplier="0.2" /></mapping>
    <mapping channel="1" key="026" command="/executor/1.3" ><param type="f" value="$fadeSpeed" multiplier="0.2" /></mapping>
    <mapping channel="1" key="027" command="/executor/1.3" ><param type="f" value="$velocity" /><param type="f" value="$fadeSpeed2" multiplier="0.1" /></mapping>


  </mappings>
  
</jmididata>