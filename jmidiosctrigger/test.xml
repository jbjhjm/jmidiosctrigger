    <mapping channel="3" key="009" command="/executor/202/goto/4.2"><param type="f" value="0.5" /></mapping>
    <mapping channel="3" key="010" command="/cmd"><param type="s" value="Select Executor 7.101" /></mapping>
  </mappings>
  
</jmididata>